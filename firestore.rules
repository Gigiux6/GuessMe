rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------
    // FUNZIONI DI SUPPORTO (HELPERS)
    // ------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Funzione richiesta: Verifica se l'utente corrisponde all'UID in modifica/lettura
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getHostId(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId;
    }
    
    function isHost(roomId) {
      return isAuthenticated() && getHostId(roomId) == request.auth.uid;
    }

    // ------------------------------------
    // REGOLE DI ACCESSO AI DATI
    // ------------------------------------

    // Collezione Utenti
    match /users/{userId} {
      // Un utente può leggere, scrivere o modificare ESCLUSIVAMENTE i propri dati.
      allow read, write: if isOwner(userId);
    }

    // Collezione Stanze (Rooms)
    match /rooms/{roomId} {
      allow read, create: if isAuthenticated();
      
      // Update permesso all'host o per parametri limitati in gioco (turni e messaggi di sistema)
      allow update: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['turnIndex', 'lastSystemMessage'])
      );
      allow delete: if isHost(roomId);
      
      // Subcollection Giocatori
      match /players/{playerId} {
        allow read: if isAuthenticated();
        // Solo il giocatore stesso (proprietario del suo slot) o l'host della partita possono modificare/eliminare
        allow create, update, delete: if isOwner(playerId) || isHost(roomId);
      }
      
      // Subcollection Risposte/Invii
      match /submissions/{playerId} {
        allow read: if isHost(roomId);
        // Ogni giocatore può inviare/modificare la PROPRIA risposta
        allow write: if isOwner(playerId);
      }
    }
  }
}
